{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpeakType Cloud CycloneDX required fields",
  "type": "object",
  "required": ["bomFormat", "specVersion", "version", "metadata", "components", "dependencies"],
  "properties": {
    "bomFormat": { "const": "CycloneDX" },
    "specVersion": { "const": "1.5" },
    "version": { "type": "integer", "minimum": 1 },
    "metadata": {
      "type": "object",
      "required": ["component"],
      "properties": {
        "component": { "$ref": "#/definitions/component" }
      }
    },
    "components": {
      "type": "array",
      "items": { "$ref": "#/definitions/component" }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "dependsOn"],
        "properties": {
          "ref": { "type": "string", "minLength": 1 },
          "dependsOn": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    }
  },
  "definitions": {
    "component": {
      "type": "object",
      "required": ["type", "name", "version", "bom-ref", "purl"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "bom-ref": { "type": "string", "minLength": 1 },
        "purl": { "type": "string", "pattern": "^pkg:cargo/" }
      }
    }
  }
}
